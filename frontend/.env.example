# ---------------------------------------------------------
# Archivo de Ejemplo: Variables de Entorno (Frontend)
# Copia este archivo como .env.local para desarrollo
# ---------------------------------------------------------

# URL del Backend API (Local por defecto)
VITE_API_URL=http://localhost:5241

# Configuración de Supabase (Obtenlas de Settings -> API en Supabase)
VITE_SUPABASE_URL=[ ACA VA TU URL DE SUPABASE ]
VITE_SUPABASE_ANON_KEY=[ ACA VA TU ANON KEY DE SUPABASE ]

# IMPORTANTE: En Netlify, configura estas mismas variables 
# pero con la URL de tu backend en la nube (ej: Render).
